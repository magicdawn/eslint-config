{
  "name": "@magicdawn/eslint-config",
  "type": "module",
  "version": "1.6.5",
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "description": "magicdawn's eslint-config",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicdawn/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/eslint-config/issues"
  },
  "keywords": [
    "eslint-config",
    "eslint",
    "magicdawn"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsdown src/index.ts --dts --no-fixed-extension --watch",
    "build": "tsdown src/index.ts --dts --no-fixed-extension",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm typecheck && pnpm build",
    "inspect": "pnpx @eslint/config-inspector@latest"
  },
  "peerDependencies": {
    "@unocss/eslint-plugin": "^66.6.8",
    "eslint": "^10 || ^9"
  },
  "peerDependenciesMeta": {
    "@unocss/eslint-plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "@sxzz/eslint-config": "^7.8.5",
    "es-toolkit": "^1.46.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-flat-config-utils": "^3.2.0"
  },
  "devDependencies": {
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10"
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
